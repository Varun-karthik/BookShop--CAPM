<core:FragmentDefinition 
    xmlns:layout="sap.ui.layout" 
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog  title="Create Request">
    
    <form:SimpleForm
    layout="ResponsiveGridLayout">

    <Label text="ID"/>
    <Input required="true" type="Number" editable="true" id="id"/>

    <Label text="Book Name"/>
    <Input required="true" id="name"/>

    <Label text="Price"/>
    <Input type="Number" required="true" id="price"/>

    <Label text="Stock"/>
    <Input type="Number" id="stock"/>


    <Label text="Created By"/>
    <Input id="cby"/>
</form:SimpleForm>

   

   <beginButton>
    <Button text="Save" press="onSave"></Button>
   </beginButton>
   <endButton>
    <Button text="Cancel" press="onCancel"></Button>
   </endButton>
   
   </Dialog>
</core:FragmentDefinition>